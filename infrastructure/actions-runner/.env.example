# =============================================================================
# Sample-Brain Self-Hosted Runner — Environment Configuration
# =============================================================================
# Copy this file to .env.runner and fill in the required values.
#   cp .env.example .env.runner
# =============================================================================

# Required: Registration token (generate via GitHub UI or API).
# Settings > Actions > Runners > New runner > copy token
# Token expires after 1 hour. Only needed for first registration.
RUNNER_TOKEN=

# Runner name (optional, default: sample-brain-runner)
# RUNNER_NAME=sample-brain-runner

# Custom labels (optional, default: sample-brain,linux,x64)
# The standard label 'self-hosted' is added automatically by GitHub.
# RUNNER_LABELS=sample-brain,linux,x64

# Work directory inside container (optional)
# RUNNER_WORKDIR=/home/runner/_work

# GitHub repository URL (optional, default: https://github.com/jannekbuengener/sample-brain)
# GITHUB_URL=https://github.com/jannekbuengener/sample-brain

# Runner group (optional, default: default)
# RUNNER_GROUP=default

# =============================================================================
# Token Refresh
# =============================================================================
# The registration token expires after 1 hour, but it is only needed for the
# initial ./config.sh call. Once registered, the runner authenticates with its
# own credentials stored in the persistent state volume (sb-runner-state).
# A new token is required only when:
#   - the container is rebuilt from scratch
#   - the runner is manually removed in the GitHub UI
#   - the state volume is deleted or corrupted
# =============================================================================
